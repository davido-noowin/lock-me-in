{
  "manifest_version": 3,
  "name": "Lock Me In",
  "version": "1.0.0",
  "description": "A chrome extension that stops you from doomscrolling on YouTube Shorts (TikTok, Instagram, and TBD)",
  "action": {
    "default_popup": "index.html"
  },
  "permissions": [
    "declarativeNetRequest",
    "declarativeNetRequestFeedback",
    "storage",
    "webNavigation"
  ],
  "host_permissions": [
    "*://*.youtube.com/*",
    "*://*.google.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}